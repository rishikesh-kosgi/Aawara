NODE_ENV=production
PORT=5000
HOST=0.0.0.0
TRUST_PROXY=1
DATABASE_URL=postgresql://touristspot_app:replace-me@127.0.0.1:5432/touristspot
PGSSL_MODE=disable
JWT_SECRET=replace-this-with-a-long-random-secret
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_MAX=20
UPLOADS_DIR=uploads
UPLOADS_BASE_URL=https://api.yourdomain.com/uploads
GOOGLE_WEB_CLIENT_ID=replace-with-your-production-google-web-client-id
